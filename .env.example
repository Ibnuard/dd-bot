# Required: get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Optional: comma-separated Telegram chat IDs allowed to use the bot.
# Get yours from @userinfobot. Leave empty for open access.
# ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# Optional: ScraperAPI key (signup at https://www.scraperapi.com/, 5k free).
# Used as fallback when Cloudflare blocks the direct fetch.
# SCRAPERAPI_KEY=

# ----------------------------------------------------------------------------
# Web player integration (optional but recommended).
#
# When both are set, the bot replies with a "📺 Tonton di browser" link in
# addition to the raw CDN URL. The player handles Referer-protected videos
# and HLS, so users can watch directly on iOS Safari without VLC.
# ----------------------------------------------------------------------------

# Public URL of the deployed Doomsday Player (no trailing slash).
# Example: https://doomsday-player.vercel.app
PLAYER_BASE_URL=

# Shared HMAC secret. MUST match the player's STREAM_SECRET env var.
# Generate with: openssl rand -hex 32
STREAM_SECRET=
