# Required: get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Public-facing URL of THIS bot's HTTP server.
# Used to build /play links sent to chat. Must be reachable from the internet
# if you want iOS users to be able to open the link in Safari.
# Examples:
#   PUBLIC_URL=https://doomsday.example.com
#   PUBLIC_URL=http://YOUR.VPS.IP:3000
PUBLIC_URL=

# Optional: HTTP server port (default 3000)
# PORT=3000

# Optional: comma-separated Telegram chat IDs allowed to use the bot.
# Get yours from @userinfobot. Leave empty for open access.
# ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# Optional: ScraperAPI key (signup at https://www.scraperapi.com/, 5k free).
# Used as fallback when Cloudflare blocks the direct fetch.
# SCRAPERAPI_KEY=
